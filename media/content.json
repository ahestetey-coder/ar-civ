  "process": {
    "kicker": "Süreç — 05",
    "title": "Dört aşama,<br/>aynı sözleşmenin altında.",
    "steps": [
      { "num": "01", "title": "Konsept", "body": "İlk toplantı, arazi, brief. Eskizler, varyantlar ve maliyet bantları. Bu aşamada kararların yarısı verilir; geri kalan zaman çoğunlukla bunları doğrulamakla geçer.", "weeks": "2 — 6 hafta" },
      { "num": "02", "title": "Tasarım", "body": "Ön projeden tatbikat projesine. Mimari, iç mimari, statik, mekanik, elektrik koordinasyonu. Ruhsat dosyası bu aşamada kapanır.", "weeks": "10 — 24 hafta" },
      { "num": "03", "title": "İnşaat", "body": "Saha kurulumu, taşeron seçimi, günlük denetim. Atölyeden bir mimar haftada en az iki gün sahadadır. Değişiklikler tek bir koordinatör üzerinden ilerler.", "weeks": "8 — 22 ay" },
      { "num": "04", "title": "Yaşam", "body": "Teslim sonrası ilk 24 ay boyunca atölye, mekânı periyodik olarak ziyaret eder. Eskime, ısı, akustik geri bildirimleri sonraki projeye girdi olur.", "weeks": "24 ay sonrası" }
    ]
  },

